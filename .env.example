# Copy this file to `.env` in the repository root.
# direnv loads `.env` through `.envrc`, so both the SvelteKit frontend and
# FastAPI backend inherit these variables when you run commands from this repo.

# Frontend / Supabase auth
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional browser-facing API base. Leave empty for the same-origin SvelteKit
# /api proxy, which is the default and the recommended Coolify setup.
PUBLIC_BACKEND_API_URL=

# Internal FastAPI target used by the SvelteKit /api proxy.
BACKEND_API_URL=
INTERNAL_BACKEND_API_URL=

# FastAPI CORS origins. Leave empty for same-origin proxy deployments.
PUBLICUS_CORS_ORIGINS=

# Supabase service access for FastAPI dataset ingestion, pipeline reads, semantic search, and pgvector caching.
# Do not expose this service role key in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PUBLICUS_PIPELINE_ADMIN_TOKEN=

# Google Gemini embeddings. The 1536 dimensions match the Supabase
# opportunity_embeddings.embedding vector(1536) migration.
PUBLICUS_EMBEDDING_PROVIDER=google
PUBLICUS_EMBEDDING_DIMENSIONS=1536
PUBLICUS_GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
PUBLICUS_GOOGLE_EMBEDDING_BATCH_SIZE=100
PUBLICUS_GOOGLE_EMBEDDING_TASK_TYPE=SEMANTIC_SIMILARITY
GEMINI_API_KEY=

# Gemini generation for company profile drafting and opportunity analysis.
PUBLICUS_GEMINI_GENERATION_MODEL=gemini-3-flash-preview

# Equivalent Google API key variable names also supported by the backend:
# GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Optional explicit OpenAI fallback, disabled by default:
# PUBLICUS_EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
